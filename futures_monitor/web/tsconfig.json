{
  "contract": {
    "role": "Define TypeScript compiler baseline for Vue application.",
    "depends": ["typescript", "vue"],
    "exports": ["compilerOptions", "include"],
    "status": "IMPLEMENTED",
    "functions": ["TypeScript type checking for src/**/*.ts and src/**/*.vue"]
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "vite.config.ts"]
}
